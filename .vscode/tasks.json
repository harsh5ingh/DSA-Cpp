{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Compile C++",
      "type": "shell",
      "command": "g++",
      "args": [
        "-Wall",
        "-Wextra",
        "-g3",
        "d:\\Coding\\DSA C++\\Basic\\patten1.cpp",
        "-o",
        "d:\\Coding\\DSA C++\\Basic\\output\\patten1.exe"
